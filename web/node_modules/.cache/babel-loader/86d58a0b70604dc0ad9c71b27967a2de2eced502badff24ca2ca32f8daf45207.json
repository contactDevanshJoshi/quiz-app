ge.getItem('quiz_user');\r\n    const storedRole = localStorage.getItem('quiz_role');\r\n    if (stored) {\r\n      setUser(JSON.parse(stored));\r\n      setRole(storedRole);\r\n    }\r\n    setLoading(false);\r\n  }, []);\r\n\r\n  const login = (userData, userRole) => {\r\n    setUser(userData);\r\n    setRole(userRole);\r\n    localStorage.setItem('quiz_user', JSON.stringify(userData));\r\n    localStorage.setItem('quiz_role', userRole);\r\n  };\r\n\r\n  const logout = () => {\r\n    setUser(null);\r\n    setRole(null);\r\n    localStorage.removeItem('quiz_user');\r\n    localStorage.removeItem('quiz_role');\r\n  };\r\n\r\n  return (\r\n    <AuthContext.Provider value={{ user, role, login, logout, loading }}>\r\n      {children}\r\n    </AuthContext.Provider>\r\n  );\r\n}\r\n\r\nexport const useAuth = () => useContext(AuthContext);\r\n\r\n"],"mappings":"AAAA;AACA,OAASA,QAAQ,CAAEC,SAAS,CAAEC,aAAa,CAAEC,UAAU,KAAQ,OAAO,CAAC,OAAAC,GAAA,IAAAC,IAAA,yBAEvE,KAAM,CAAAC,WAAW,cAAGJ,aAAa,CAAC,IAAI,CAAC,CAEvC,MAAO,SAAS,CAAAK,YAAYA,CAAAC,IAAA,CAAe,IAAd,CAAEC,QAAS,CAAC,CAAAD,IAAA,CACvC,KAAM,CAACE,IAAI,CAAEC,OAAO,CAAC,CAAGX,QAAQ,CAAC,IAAI,CAAC,CACtC,KAAM,CAACY,IAAI,CAAEC,OAAO,CAAC,CAAGb,QAAQ,CAAC,IAAI,CAAC,CAAE;AACxC,KAAM,CAACc,OAAO,CAAEC,UAAU,CAAC,CAAGf,QAAQ,CAAC,IAAI,CAAC,CAE5CC,SAAS,CAAC,IAAM,CACd,KAAM,CAAAe,MAAM,CAAGC,YAAY,CAACC,OAAO,CAAC,WAAW,CAAC,CAChD,KAAM,CAAAC,UAAU,CAAGF,YAAY,CAACC,OAAO,CAAC,WAAW,CAAC,CACpD,GAAIF,MAAM,CAAE,CACVL,OAAO,CAACS,IAAI,CAACC,KAAK,CAACL,MAAM,CAAC,CAAC,CAC3BH,OAAO,CAACM,UAAU,CAAC,CACrB,CACAJ,UAAU,CAAC,KAAK,CAAC,CACnB,CAAC,CAAE,EAAE,CAAC,CAEN,KAAM,CAAAO,KAAK,CAAGA,CAACC,QAAQ,CAAEC,QAAQ,GAAK,CACpCb,OAAO,CAACY,QAAQ,CAAC,CACjBV,OAAO,CAACW,QAAQ,CAAC,CACjBP,YAAY,CAACQ,OAAO,CAAC,WAAW,CAAEL,IAAI,CAACM,SAAS,CAACH,QAAQ,CAAC,CAAC,CAC3DN,YAAY,CAACQ,OAAO,CAAC,WAAW,CAAED,QAAQ,CAAC,CAC7C,CAAC,CAED,KAAM,CAAAG,MAAM,CAAGA,CAAA,GAAM,CACnBhB,OAAO,CAAC,IAAI,CAAC,CACbE,OAAO,CAAC,IAAI,CAAC,CACbI,YAAY,CAACW,UAAU,CAAC,WAAW,CAAC,CACpCX,YAAY,CAACW,UAAU,CAAC,WAAW,CAAC,CACtC,